rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function tokenEmail() {
      return request.auth.token.email;
    }

    function isSuperAdminEmail() {
      return signedIn() && tokenEmail() == 'talibhassan1122@gmail.com';
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function myRole() {
      return userDoc(request.auth.uid).data.role;
    }

    function isAdmin() {
      return signedIn() && (
        isSuperAdminEmail() ||
        (userExists(request.auth.uid) && (
          myRole() == 'admin' ||
          myRole() == 'super_admin'
        ))
      );
    }

    function listOrEmpty(x) {
      return x is list ? x : [];
    }

    function assignedSitesOverlap(ca, sa) {
      let a = listOrEmpty(ca);
      let b = listOrEmpty(sa);
      return a.size() == 0 && b.size() == 0
        || (a.size() > 0 && b.size() > 0 && a.hasAny(b));
    }

    /** Mirrors `lib/attendance/proxy-attendance.ts`. */
    function isAdminRecordingFor(workerUid) {
      let cr = userDoc(request.auth.uid).data.role;
      let sr = userDoc(workerUid).data.role;
      return (cr == 'admin' || cr == 'super_admin')
        && (sr == 'employee' || sr == 'admin');
    }

    function employeePairOk(callerUid, workerUid) {
      let c = userDoc(callerUid).data;
      let s = userDoc(workerUid).data;
      return c.role == 'employee' && s.role == 'employee'
        && assignedSitesOverlap(c.assignedSites, s.assignedSites);
    }

    function canRecordAttendanceFor(callerUid, workerUid) {
      return callerUid is string && workerUid is string
        && userExists(callerUid) && userExists(workerUid)
        && (callerUid == workerUid
          || isAdminRecordingFor(workerUid)
          || employeePairOk(callerUid, workerUid));
    }

    function attendanceIdMatchesData() {
      return request.resource.data.workerId is string
        && request.resource.data.date is string
        && docId == request.resource.data.workerId + '_' + request.resource.data.date;
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId || isAdmin() ||
        (userExists(request.auth.uid) && myRole() == 'employee'
          && resource.data.role == 'employee')
      );

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'employee'
        && request.resource.data.email == tokenEmail()
        && request.resource.data.name is string
        && request.resource.data.assignedSites is list;

      allow update, delete: if isSuperAdminEmail();

      // timeZone may change (device sync); other privileged fields stay fixed.
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.assignedSites == resource.data.assignedSites
        && request.resource.data.email == tokenEmail()
        && request.resource.data.timeZone is string;

      allow update: if signedIn()
        && isAdmin()
        && !isSuperAdminEmail()
        && resource.data.role == 'employee'
        && request.resource.data.role == 'employee';

      allow update: if signedIn()
        && isAdmin()
        && !isSuperAdminEmail()
        && resource.data.role == 'employee'
        && request.resource.data.role == 'admin'
        && request.resource.data.email == resource.data.email
        && request.resource.data.assignedSites == resource.data.assignedSites;

      allow delete: if signedIn() && (request.auth.uid == userId || isSuperAdminEmail());
    }

    match /sites/{siteId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /attendance/{docId} {
      allow read: if signedIn()
        && (resource.data.workerId == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && attendanceIdMatchesData()
        && canRecordAttendanceFor(request.auth.uid, request.resource.data.workerId);

      allow update: if signedIn()
        && resource.data.workerId == request.resource.data.workerId
        && attendanceIdMatchesData()
        && canRecordAttendanceFor(request.auth.uid, resource.data.workerId);

      allow delete: if signedIn() && resource.data.workerId == request.auth.uid;
    }

    match /live_tracking/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /notifications/{id} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && isAdmin();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /overtimeRequests/{id} {
      allow read: if signedIn()
        && (resource.data.workerId == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.workerId == request.auth.uid;
      allow update: if signedIn() && isAdmin();
      allow delete: if false;
    }

    match /offsiteWorkRequests/{id} {
      allow read: if signedIn()
        && (resource.data.workerId == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.workerId == request.auth.uid;
      allow update: if signedIn() && isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
