# --- Firebase (client) ---
# Firebase Console → Project settings → Your apps → Web app → npm / SDK setup snippet.
# Each NEXT_PUBLIC_* maps to firebaseConfig: apiKey, authDomain, projectId, storageBucket,
# messagingSenderId, appId. Copy the values from that object into .env.local (not committed).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Often "<projectId>.firebasestorage.app" (new default); older projects may use "<projectId>.appspot.com"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — same snippet as measurementId (Firebase / Google Analytics)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: must match firestore.rules isSuperAdminEmail() and SUPER_ADMIN_EMAIL
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=you@example.com

# --- Firebase Admin (server only) ---
# Option A (Vercel / env var): ONE-LINE JSON. Escape private_key newlines as \\n
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'

# Option B (local): path from project root
# FIREBASE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# Option C: standard Google env
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/or/relative/path/to/service-account.json

# Super admin bypass for /api/admin/* when Firestore user doc is not promoted yet
SUPER_ADMIN_EMAIL=you@example.com

# Cron: schedule GET /api/cron/auto-checkout with Authorization: Bearer CRON_SECRET (e.g. Vercel Cron)
CRON_SECRET=

# Optional: valid URL stored on automatic check-out records (Firebase-friendly)
# AUTO_CHECKOUT_PLACEHOLDER_URL=https://invalid.invalid/attendance-auto-checkout

# --- Vercel Blob — Storage → Create token (read/write) ---
BLOB_READ_WRITE_TOKEN=
# Must match store access in Vercel: omit or "private" (default). Use "public" only if the store is public.
# BLOB_STORE_ACCESS=private
